# Frontend build/serve config. Copy to .env.local for local overrides.

# Backend API base URL. For local Compose this is the host-mapped backend port.
VITE_API_BASE=http://localhost:8000

# NOTE: For real Telegram Mini App testing this becomes the HTTPS tunnel origin
# (cloudflared / ngrok) and MUST be allowed by the WebView CSP `connect-src`
# (RESEARCH Open Question #5) or the in-app fetch will be blocked.
#
# DEPLOY (timeweb): Vite inlines VITE_API_BASE at BUILD time, so it is passed to the
# frontend Docker image as a build-arg, NOT a runtime env:
#   --build-arg VITE_API_BASE=https://<backend-app>.timeweb.cloud
# It must equal the backend app's HTTPS origin and be listed in the backend CORS_ORIGINS.

# DEV-ONLY: mock Telegram initData so the auth flow is testable in a plain browser
# (no real Telegram WebView). Read ONLY under import.meta.env.DEV — never shipped to
# production. Set this to a value signed by your test BOT_TOKEN (the backend validates
# the two-stage HMAC; an unsigned/garbage value will be rejected with a 401, which is
# the correct in-character error path). Leave empty to test the "not in Telegram" state.
VITE_DEV_INIT_DATA=
