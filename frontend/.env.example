# Frontend build/serve config. Copy to .env.local for local overrides.

# Backend API base URL. For local Compose this is the host-mapped backend port.
VITE_API_BASE=http://localhost:8000

# NOTE: For real Telegram Mini App testing this becomes the HTTPS tunnel origin
# (cloudflared / ngrok) and MUST be allowed by the WebView CSP `connect-src`
# (RESEARCH Open Question #5) or the in-app fetch will be blocked.
