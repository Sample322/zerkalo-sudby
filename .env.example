# Зеркало Судьбы — environment template.
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# Every NAME here is a contract the backend reads at startup; missing a required
# secret makes the process fail fast with a ValidationError (INFRA-04).

# --- Required secrets (no default — boot fails if absent) ---
BOT_TOKEN=
# Async DSN form. For `docker compose up`, compose overrides host/port to service names.
DATABASE_URL=postgresql+asyncpg://zerkalo:zerkalo@postgres:5432/zerkalo
REDIS_URL=redis://redis:6379/0
JWT_SECRET=
# --- ЮKassa (YooKassa) payments (Phase 7, D-01) — REQUIRED, no default (boot fails if absent) ---
# From the ЮKassa merchant dashboard: shopId (username) + secret key (password), HTTP Basic.
# NEVER commit real values (T-07-SECRET-LEAK). Test mode: use the sandbox shop id + secret.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# --- LLM provider: at least ONE key required (boot fails if both absent) ---
# Default provider: Anthropic (claude-haiku-4-5 via messages.parse Structured Outputs).
ANTHROPIC_API_KEY=
# OpenRouter (OpenAI-compatible gateway): when set, the backend routes generation + safety
# through it via app/core/openrouter_adapter.py instead of Anthropic. Cheap test model default.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Admin allowlist ---
# Comma-separated Telegram user IDs, NO brackets. Example: 111,222
ADMIN_TELEGRAM_IDS=

# --- Optional / tunable (defaults applied when omitted) ---
# JWT_EXPIRE_SECONDS=604800
# INITDATA_MAX_AGE_SECONDS=86400
# LOG_LEVEL=INFO
# Telegram bot-api secret header — NOT used by ЮKassa (its webhooks are UNSIGNED → defended by
# IP-allowlist + re-fetch, not a header secret). Left here harmless for a possible future bot.
WEBHOOK_SECRET=
# ЮKassa webhook source allowlist (optional override) — comma-separated CIDR/IPs, NO brackets.
# Empty => the service uses its built-in published ЮKassa ranges. Re-fetch-by-id is the real
# guard; this is defence-in-depth. Example:
# YOOKASSA_WEBHOOK_IPS=185.71.76.0/27,185.71.77.0/27,77.75.153.0/25,2a02:5180::/32

# --- Deploy (timeweb.cloud) ---
# CORS: comma-separated allowed origins = the deployed frontend (nginx app) HTTPS URL(s).
# Empty => CORS middleware is not installed (local docker-compose / same-origin / dev).
# Example: CORS_ORIGINS=https://zerkalo-frontend.timeweb.cloud
CORS_ORIGINS=
# The backend entrypoint runs `alembic upgrade head` + `python -m app.seed` on start
# (both idempotent). Set RUN_MIGRATIONS=0 to skip (multi-instance / separate release job).
# RUN_MIGRATIONS=1
