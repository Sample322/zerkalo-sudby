# Зеркало Судьбы — environment template.
# Copy to .env and fill in real values. NEVER commit .env (it is gitignored).
# Every NAME here is a contract the backend reads at startup; missing a required
# secret makes the process fail fast with a ValidationError (INFRA-04).

# --- Required secrets (no default — boot fails if absent) ---
BOT_TOKEN=
# Async DSN form. For `docker compose up`, compose overrides host/port to service names.
DATABASE_URL=postgresql+asyncpg://zerkalo:zerkalo@postgres:5432/zerkalo
REDIS_URL=redis://redis:6379/0
JWT_SECRET=
# Required at startup per INFRA-04 even though unused until Phase 4.
ANTHROPIC_API_KEY=

# --- Admin allowlist ---
# Comma-separated Telegram user IDs, NO brackets. Example: 111,222
ADMIN_TELEGRAM_IDS=

# --- Optional / tunable (defaults applied when omitted) ---
# JWT_EXPIRE_SECONDS=604800
# INITDATA_MAX_AGE_SECONDS=86400
# LOG_LEVEL=INFO
# Telegram webhook secret header — reserved for Phase 7 (bot wiring).
WEBHOOK_SECRET=

# --- Deploy (timeweb.cloud) ---
# CORS: comma-separated allowed origins = the deployed frontend (nginx app) HTTPS URL(s).
# Empty => CORS middleware is not installed (local docker-compose / same-origin / dev).
# Example: CORS_ORIGINS=https://zerkalo-frontend.timeweb.cloud
CORS_ORIGINS=
# The backend entrypoint runs `alembic upgrade head` + `python -m app.seed` on start
# (both idempotent). Set RUN_MIGRATIONS=0 to skip (multi-instance / separate release job).
# RUN_MIGRATIONS=1
